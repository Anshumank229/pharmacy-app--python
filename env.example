# .env.example
# Copy this to .env and fill in real values.
# NEVER commit .env to git. It is already in .gitignore — keep it that way.
#
# ============================================================
# HOW TO GENERATE STRONG SECRETS (run these in your terminal):
# ============================================================
#
#   JWT_SECRET:
#       python -c "import secrets; print(secrets.token_hex(64))"
#
#   ADMIN_API_KEY:
#       python -c "import secrets; print(secrets.token_urlsafe(48))"
#
#   DJANGO_SECRET_KEY:
#       python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
#
# ============================================================
# ROTATE IMMEDIATELY — your current values are:
#   ADMIN_API_KEY=Anshuman2002@       ← guessable
#   DJANGO_SECRET_KEY=Anshuman2002@   ← guessable
#   DB password=anshuman2002         ← same password everywhere
#   Google OAuth creds               ← exposed in public repo
#   Gmail app password               ← exposed in public repo
# ============================================================

# --- Django ---
DJANGO_SECRET_KEY=replace-with-output-of-get_random_secret_key
DEBUG=False

# --- Database ---
DATABASE_URL=postgresql://your_db_user:STRONG_RANDOM_PASSWORD@localhost:5432/pharmacy_db

# --- JWT (new — add this) ---
JWT_SECRET=replace-with-64-char-hex-from-secrets.token_hex
JWT_EXPIRE_MINUTES=1440

# --- Admin API key (static key auth — keep rotating) ---
# Use: python -c "import secrets; print(secrets.token_urlsafe(48))"
ADMIN_API_KEY=replace-with-urlsafe-token

# --- Google OAuth ---
# Rotate at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-new-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-new-client-secret

# --- Email ---
# Rotate Gmail App Password at: https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-new-app-password

# --- Storage ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
USE_SUPABASE_STORAGE=True

# --- App ---
STREAMLIT_URL=https://your-streamlit-domain.com
