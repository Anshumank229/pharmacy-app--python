# Copy this file to .env and fill in your real values
# Never commit .env to GitHub

# Django
DJANGO_SECRET_KEY=generate-a-50-char-random-string-here
DEBUG=False
ALLOWED_HOSTS=your-app.up.railway.app

# Database — paste from Railway Postgres plugin dashboard
DATABASE_URL=postgresql://postgres:password@host:5432/railway

# Google OAuth — from Google Cloud Console
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=https://your-app.up.railway.app/complete/google-oauth2/

# Streamlit frontend URL — fill after deploying to Streamlit Cloud
STREAMLIT_URL=https://your-app.streamlit.app

# Admin panel key — make this a strong random string
ADMIN_API_KEY=generate-a-strong-random-key-here

# Email — use Gmail App Password (not your real Gmail password)
EMAIL_HOST_USER=youremail@gmail.com
EMAIL_HOST_PASSWORD=xxxx xxxx xxxx xxxx

# Supabase — from your Supabase project settings
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=your-anon-public-key
SUPABASE_BUCKET=medicine-images